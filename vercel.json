{
  "version": 2,
  "name": "mitv-masking-engine",
  "rewrites": [
    { "source": "/player_api.php", "destination": "/api/m3u" },
    { "source": "/get.php", "destination": "/api/m3u" },
    { "source": "/xmltv.php", "destination": "/api/m3u" },
    { "source": "/m3u/:token", "destination": "/api/m3u?token=:token" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
